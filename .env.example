# ============================================================
# AI Sentiment Analysis — Environment Variables
# Copy this file to .env and fill in your actual credentials
# ============================================================

# MySQL (Blue Eye Database)
MYSQL_HOST=10.x.x.x
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=blue_eye

# MongoDB (Blue Eye Content Store)
MONGO_HOST=10.x.x.x
MONGO_PORT=34596
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DB=blue_eye
