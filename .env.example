# ============================================================
# .env.example — ไฟล์ตัวอย่างสำหรับตั้งค่า Environment
# ให้คัดลอกไฟล์นี้เป็นชื่อ .env แล้วใส่ค่าจริงลงไป
# ============================================================

# MySQL (Blue Eye Database)
MYSQL_HOST=10.x.x.x
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=blue_eye

# MongoDB (Blue Eye Content Store)
MONGO_HOST=10.x.x.x
MONGO_PORT=34596
MONGO_USER=your_mongo_user
MONGO_PASSWORD=your_mongo_password
MONGO_DB=blue_eye

# ─── การตั้งค่า run_forever.py ───────────────────────────────
# mockup = ใช้ข้อมูลจำลอง (ทดสอบ Prompt โดยไม่ต้องเชื่อม DB)
# db     = ดึงข้อมูลจาก MySQL + MongoDB จริง
RUN_MODE=db

# รอกี่นาทีก่อนรันรอบถัดไป
RUN_INTERVAL_MINUTES=1

# ─── SSH Tunnel ──────────────────────────────────────────────
SSH_HOST=your_ssh_host_ip
SSH_PORT=22
SSH_USER=your_ssh_user
SSH_PASSWORD=your_ssh_password

# SSH Tunnel → MySQL (server 1)
SSH_MYSQL_HOST_1=your_mysql_ssh_host_1
SSH_MYSQL_USER_1=your_mysql_ssh_user_1
SSH_MYSQL_PASSWORD_1=your_mysql_ssh_password_1

# SSH Tunnel → MySQL (server 2)
SSH_MYSQL_HOST_2=your_mysql_ssh_host_2
SSH_MYSQL_USER_2=your_mysql_ssh_user_2
SSH_MYSQL_PASSWORD_2=your_mysql_ssh_password_2

# ─── DigitalOcean Spaces ─────────────────────────────────────
DO_SPACES_REGION=sgp1
DO_SPACES_ACCESS_KEY=your_do_spaces_access_key
DO_SPACES_SECRET_KEY=your_do_spaces_secret_key
DO_SPACES_BUCKET=your_do_spaces_bucket
